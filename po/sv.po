msgid "Settings"
msgstr "Inställningar"

msgid "Global Preferences"
msgstr "Globala inställningar"

msgid "Configure behavior, timing, and sources."
msgstr "Konfigurera beteende, tidsintervall och källor."

msgid "Randomize / Shuffle"
msgstr "Slumpa / Blanda"

msgid "Turn off to assign static wallpapers sequentially per monitor."
msgstr "Stäng av för att tilldela statiska bakgrunder sekventiellt per skärm."

msgid "Same Image on All Monitors"
msgstr "Samma bild på alla skärmar"

msgid "Apply one background to all displays. Requires a multi-monitor setup."
msgstr "Applicera en bakgrund på alla skärmar. Kräver flera skärmar."

msgid "Change Interval (Minutes)"
msgstr "Ändringsintervall (Minuter)"

msgid "Frequency of background cycling."
msgstr "Frekvens för bakgrundsbyte."

msgid "Wallpaper Source"
msgstr "Bakgrundskälla"

msgid "Where to fetch backgrounds from."
msgstr "Varifrån bakgrunder hämtas."

msgid "Local Folder"
msgstr "Lokal mapp"

msgid "Online Random (Picsum)"
msgstr "Online slumpmässig (Picsum)"

msgid "Online Random (LoremFlickr)"
msgstr "Online slumpmässig (LoremFlickr)"

msgid "Wallpaper Folder"
msgstr "Bakgrundsmapp"

msgid "Select a directory..."
msgstr "Välj en katalog..."

msgid "Select Wallpaper Source Folder"
msgstr "Välj källmapp för bakgrunder"

msgid "Per-Monitor Configuration"
msgstr "Konfiguration per skärm"

msgid "Assign individual scaling strategies and static images to connected displays."
msgstr "Tilldela individuella skaleringsstrategier och statiska bilder till skärmar."

msgid "Unknown Display"
msgstr "Okänd skärm"

msgid "Display %d"
msgstr "Skärm %d"

msgid "Scaling Strategy"
msgstr "Skaleringsstrategi"

msgid "Specific Static Image"
msgstr "Specifik statisk bild"

msgid "Default (Alphabetical from folder)"
msgstr "Standard (Alfabetisk från mapp)"

msgid "Select Static Image for %s"
msgstr "Välj statisk bild för %s"

msgid "About"
msgstr "Om"

msgid "Extension Information"
msgstr "Tilläggsinformation"

msgid "Wallshuffle"
msgstr "Wallshuffle"

msgid "Set dynamic, per-monitor backgrounds using advanced rendering strategies."
msgstr "Ställ in dynamiska bakgrunder per skärm med avancerade strategier."

msgid "Version"
msgstr "Version"

msgid "Local / Development"
msgstr "Lokalt / Utveckling"

msgid "Author"
msgstr "Författare"

msgid "Buy me a coffee"
msgstr "Köp mig en kaffe"

msgid "Report a Bug"
msgstr "Rapportera en bugg"

msgid "Request a Feature"
msgstr "Föreslå en funktion"

msgid "Zoom"
msgstr "Zooma"

msgid "Fit"
msgstr "Anpassa"

msgid "Centre"
msgstr "Centrera"

msgid "Fill"
msgstr "Fyll"

msgid "Tile"
msgstr "Sida vid sida"

msgid "Span"
msgstr "Spänn över"

msgid "Make Every Workspace Your Own"
msgstr "Gör varje arbetsyta till din egen"

msgid "Use different wallpapers and rendering styles per workspace even on a single-monitor setup. Enable Workspace Specificity from the Workspaces tab."
msgstr "Använd olika bakgrunder per arbetsyta även med en skärm. Aktivera på fliken Arbetsytor."

msgid "Workspaces"
msgstr "Arbetsytor"

msgid "A Visual Identity for Every Workspace"
msgstr "En visuell identitet för varje arbetsyta"

msgid "Use wallpapers to make workspaces instantly recognizable and easier to navigate."
msgstr "Använd bakgrunder för att göra arbetsytor lättare att känna igen."

msgid "Works with Any Monitor Setup"
msgstr "Fungerar med alla skärmuppsättningar"

msgid "Give every workspace its own wallpaper and scaling strategy, whether you use one monitor or several."
msgstr "Ge varje arbetsyta sin egen bakgrund, oavsett hur många skärmar du har."

msgid "Override Only What Should Be Different"
msgstr "Ändra bara det som ska vara annorlunda"

msgid "Every workspace starts with the settings from the main tab. Choose a different image or rendering mode only where needed."
msgstr "Varje arbetsyta börjar med grundinställningarna. Välj en ny bild bara där det behövs."

msgid "Workspace Specificity"
msgstr "Arbetsytespecifika inställningar"

msgid "Turn on workspace-aware backgrounds, then choose how many workspace configurations to show."
msgstr "Slå på arbetsytespecifika bakgrunder och välj antal konfigurationer att visa."

msgid "Enable Workspace Specificity"
msgstr "Aktivera arbetsytespecifika inställningar"

msgid "When disabled, Wallshuffle continues using the main per-monitor configuration."
msgstr "När inaktiverad använder Wallshuffle huvudkonfigurationen per skärm."

msgid "Brief Dark Transition When Switching"
msgstr "Kort mörk övergång vid byte"

msgid "Due to how GNOME applies workspace backgrounds, the desktop may appear dark very briefly while the next background loads. This only occurs when Workspace Specificity is enabled."
msgstr "Skrivbordet kan bli mörkt helt kort medan nästa bakgrund laddas."

msgid "Workspace Configuration Slots"
msgstr "Konfigurationsplatser för arbetsytor"

msgid "Match the number of workspaces you normally use. Add extra slots when using dynamic workspaces."
msgstr "Matcha antalet arbetsytor du normalt använder."

msgid "Per-Workspace Overrides"
msgstr "Åsidosättningar per arbetsyta"

msgid "Open a workspace below to override its inherited scaling strategy or static image for each monitor."
msgstr "Öppna en arbetsyta nedan för att åsidosätta dess inställningar för varje skärm."

msgid "Use Monitor Default"
msgstr "Använd skärmens standard"

msgid "Workspace %d"
msgstr "Arbetsyta %d"

msgid "1 connected display"
msgstr "1 ansluten skärm"

msgid "%d connected displays"
msgstr "%d anslutna skärmar"

msgid "%s Scaling Strategy"
msgstr "Skaleringsstrategi för %s"

msgid "%s   Monitor default: %s"
msgstr "%s   Skärmstandard: %s"

msgid "%s Specific Static Image"
msgstr "Specifik statisk bild för %s"

msgid "Monitor Default: %s"
msgstr "Skärmens standard: %s"

msgid "Select Static Image for Workspace %d, %s"
msgstr "Välj statisk bild för arbetsyta %d, %s"