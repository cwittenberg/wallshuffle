msgid "Settings"
msgstr "सेटिंग्स"

msgid "Global Preferences"
msgstr "वैश्विक प्राथमिकताएं"

msgid "Configure behavior, timing, and sources."
msgstr "व्यवहार, समय और स्रोतों को कॉन्फ़िगर करें।"

msgid "Randomize / Shuffle"
msgstr "यादृच्छिक / शफ़ल"

msgid "Turn off to assign static wallpapers sequentially per monitor."
msgstr "प्रत्येक मॉनिटर के लिए स्थिर वॉलपेपर सेट करने हेतु इसे बंद करें।"

msgid "Same Image on All Monitors"
msgstr "सभी मॉनिटर्स पर एक ही छवि"

msgid "Apply one background to all displays. Requires a multi-monitor setup."
msgstr "सभी डिस्प्ले पर एक ही बैकग्राउंड लागू करें। इसके लिए मल्टी-मॉनिटर सेटअप चाहिए।"

msgid "Change Interval (Minutes)"
msgstr "बदलाव का अंतराल (मिनट)"

msgid "Frequency of background cycling."
msgstr "बैकग्राउंड बदलने की आवृत्ति।"

msgid "Wallpaper Source"
msgstr "वॉलपेपर स्रोत"

msgid "Where to fetch backgrounds from."
msgstr "बैकग्राउंड कहाँ से प्राप्त करें।"

msgid "Local Folder"
msgstr "स्थानीय फ़ोल्डर"

msgid "Online Random (Picsum)"
msgstr "ऑनलाइन यादृच्छिक (Picsum)"

msgid "Online Random (LoremFlickr)"
msgstr "ऑनलाइन यादृच्छिक (LoremFlickr)"

msgid "Wallpaper Folder"
msgstr "वॉलपेपर फ़ोल्डर"

msgid "Select a directory..."
msgstr "कोई निर्देशिका चुनें..."

msgid "Select Wallpaper Source Folder"
msgstr "वॉलपेपर स्रोत फ़ोल्डर चुनें"

msgid "Per-Monitor Configuration"
msgstr "प्रति-मॉनिटर कॉन्फ़िगरेशन"

msgid "Assign individual scaling strategies and static images to connected displays."
msgstr "जुड़े हुए डिस्प्ले को अलग-अलग स्केलिंग रणनीतियाँ और चित्र असाइन करें।"

msgid "Unknown Display"
msgstr "अज्ञात डिस्प्ले"

msgid "Display %d"
msgstr "डिस्प्ले %d"

msgid "Scaling Strategy"
msgstr "स्केलिंग रणनीति"

msgid "Specific Static Image"
msgstr "विशिष्ट स्थिर छवि"

msgid "Default (Alphabetical from folder)"
msgstr "डिफ़ॉल्ट (फ़ोल्डर से वर्णमाला के अनुसार)"

msgid "Select Static Image for %s"
msgstr "%s के लिए स्थिर छवि चुनें"

msgid "About"
msgstr "के बारे में"

msgid "Extension Information"
msgstr "एक्सटेंशन जानकारी"

msgid "Wallshuffle"
msgstr "Wallshuffle"

msgid "Set dynamic, per-monitor backgrounds using advanced rendering strategies."
msgstr "उन्नत प्रतिपादन रणनीतियों का उपयोग करके प्रति-मॉनिटर डायनामिक बैकग्राउंड सेट करें।"

msgid "Version"
msgstr "संस्करण"

msgid "Local / Development"
msgstr "स्थानीय / विकास"

msgid "Author"
msgstr "लेखक"

msgid "Buy me a coffee"
msgstr "मुझे एक कॉफ़ी पिलाएँ"

msgid "Report a Bug"
msgstr "बग रिपोर्ट करें"

msgid "Request a Feature"
msgstr "नई सुविधा का अनुरोध करें"

msgid "Zoom"
msgstr "ज़ूम करें"

msgid "Fit"
msgstr "फ़िट करें"

msgid "Centre"
msgstr "केंद्र"

msgid "Fill"
msgstr "भरें"

msgid "Tile"
msgstr "टाइल"

msgid "Span"
msgstr "फैलाएं"

msgid "Make Every Workspace Your Own"
msgstr "हर वर्कस्पेस को अपना बनाएं"

msgid "Use different wallpapers and rendering styles per workspace even on a single-monitor setup. Enable Workspace Specificity from the Workspaces tab."
msgstr "सिंगल-मॉनिटर सेटअप पर भी हर वर्कस्पेस के लिए अलग वॉलपेपर इस्तेमाल करें। इसे वर्कस्पेस टैब से सक्षम करें।"

msgid "Workspaces"
msgstr "वर्कस्पेस"

msgid "A Visual Identity for Every Workspace"
msgstr "हर वर्कस्पेस के लिए एक दृश्य पहचान"

msgid "Use wallpapers to make workspaces instantly recognizable and easier to navigate."
msgstr "वर्कस्पेस को तुरंत पहचानने योग्य बनाने के लिए वॉलपेपर का उपयोग करें।"

msgid "Works with Any Monitor Setup"
msgstr "किसी भी मॉनिटर सेटअप के साथ काम करता है"

msgid "Give every workspace its own wallpaper and scaling strategy, whether you use one monitor or several."
msgstr "चाहे आप एक मॉनिटर का उपयोग करें या कई, प्रत्येक वर्कस्पेस को उसका अपना वॉलपेपर दें।"

msgid "Override Only What Should Be Different"
msgstr "केवल उसे बदलें जो अलग होना चाहिए"

msgid "Every workspace starts with the settings from the main tab. Choose a different image or rendering mode only where needed."
msgstr "हर वर्कस्पेस मुख्य टैब की सेटिंग से शुरू होता है। केवल आवश्यकता होने पर ही नई छवि चुनें।"

msgid "Workspace Specificity"
msgstr "वर्कस्पेस विशिष्टता"

msgid "Turn on workspace-aware backgrounds, then choose how many workspace configurations to show."
msgstr "वर्कस्पेस-जागरूक बैकग्राउंड चालू करें, और चुनें कि कितने कॉन्फ़िगरेशन दिखाने हैं।"

msgid "Enable Workspace Specificity"
msgstr "वर्कस्पेस विशिष्टता सक्षम करें"

msgid "When disabled, Wallshuffle continues using the main per-monitor configuration."
msgstr "अक्षम होने पर, वॉलशफ़ल मुख्य मॉनिटर कॉन्फ़िगरेशन का उपयोग करना जारी रखता है।"

msgid "Brief Dark Transition When Switching"
msgstr "स्विच करते समय संक्षिप्त डार्क ट्रांज़िशन"

msgid "Due to how GNOME applies workspace backgrounds, the desktop may appear dark very briefly while the next background loads. This only occurs when Workspace Specificity is enabled."
msgstr "गनोम के बैकग्राउंड लागू करने के तरीके के कारण, बैकग्राउंड लोड होते समय डेस्कटॉप बहुत संक्षेप में डार्क दिखाई दे सकता है।"

msgid "Workspace Configuration Slots"
msgstr "वर्कस्पेस कॉन्फ़िगरेशन स्लॉट"

msgid "Match the number of workspaces you normally use. Add extra slots when using dynamic workspaces."
msgstr "उन वर्कस्पेस की संख्या से मिलान करें जिनका आप सामान्यतः उपयोग करते हैं।"

msgid "Per-Workspace Overrides"
msgstr "प्रति-वर्कस्पेस ओवरराइड"

msgid "Open a workspace below to override its inherited scaling strategy or static image for each monitor."
msgstr "प्रत्येक मॉनिटर के लिए इसकी स्केलिंग रणनीति या स्थिर छवि को ओवरराइड करने के लिए नीचे वर्कस्पेस खोलें।"

msgid "Use Monitor Default"
msgstr "मॉनिटर डिफ़ॉल्ट का उपयोग करें"

msgid "Workspace %d"
msgstr "वर्कस्पेस %d"

msgid "1 connected display"
msgstr "1 कनेक्टेड डिस्प्ले"

msgid "%d connected displays"
msgstr "%d कनेक्टेड डिस्प्ले"

msgid "%s Scaling Strategy"
msgstr "%s स्केलिंग रणनीति"

msgid "%s   Monitor default: %s"
msgstr "%s   मॉनिटर डिफ़ॉल्ट: %s"

msgid "%s Specific Static Image"
msgstr "%s विशिष्ट स्थिर छवि"

msgid "Monitor Default: %s"
msgstr "मॉनिटर डिफ़ॉल्ट: %s"

msgid "Select Static Image for Workspace %d, %s"
msgstr "वर्कस्पेस %d, %s के लिए स्थिर छवि चुनें"