msgid "Settings"
msgstr "Ustawienia"

msgid "Global Preferences"
msgstr "Preferencje globalne"

msgid "Configure behavior, timing, and sources."
msgstr "Skonfiguruj zachowanie, czas i źródła."

msgid "Randomize / Shuffle"
msgstr "Losowo / Tasuj"

msgid "Turn off to assign static wallpapers sequentially per monitor."
msgstr "Wyłącz, aby przypisywać statyczne tapety sekwencyjnie na monitor."

msgid "Same Image on All Monitors"
msgstr "Ten sam obraz na wszystkich monitorach"

msgid "Apply one background to all displays. Requires a multi-monitor setup."
msgstr "Zastosuj jedno tło do wszystkich ekranów. Wymaga konfiguracji wielomonitorowej."

msgid "Change Interval (Minutes)"
msgstr "Interwał zmian (minuty)"

msgid "Frequency of background cycling."
msgstr "Częstotliwość zmian tła."

msgid "Wallpaper Source"
msgstr "Źródło tapet"

msgid "Where to fetch backgrounds from."
msgstr "Skąd pobierać tła."

msgid "Local Folder"
msgstr "Lokalny folder"

msgid "Online Random (Picsum)"
msgstr "Losowe Online (Picsum)"

msgid "Online Random (LoremFlickr)"
msgstr "Losowe Online (LoremFlickr)"

msgid "Wallpaper Folder"
msgstr "Folder tapet"

msgid "Select a directory..."
msgstr "Wybierz katalog..."

msgid "Select Wallpaper Source Folder"
msgstr "Wybierz folder źródłowy tapet"

msgid "Per-Monitor Configuration"
msgstr "Konfiguracja na monitor"

msgid "Assign individual scaling strategies and static images to connected displays."
msgstr "Przypisz indywidualne strategie skalowania do podłączonych ekranów."

msgid "Unknown Display"
msgstr "Nieznany ekran"

msgid "Display %d"
msgstr "Ekran %d"

msgid "Scaling Strategy"
msgstr "Strategia skalowania"

msgid "Specific Static Image"
msgstr "Określony obraz statyczny"

msgid "Default (Alphabetical from folder)"
msgstr "Domyślny (alfabetycznie z folderu)"

msgid "Select Static Image for %s"
msgstr "Wybierz obraz statyczny dla %s"

msgid "About"
msgstr "O programie"

msgid "Extension Information"
msgstr "Informacje o rozszerzeniu"

msgid "Wallshuffle"
msgstr "Wallshuffle"

msgid "Set dynamic, per-monitor backgrounds using advanced rendering strategies."
msgstr "Ustaw dynamiczne tła dla poszczególnych monitorów."

msgid "Version"
msgstr "Wersja"

msgid "Local / Development"
msgstr "Lokalnie / Rozwój"

msgid "Author"
msgstr "Autor"

msgid "Buy me a coffee"
msgstr "Kup mi kawę"

msgid "Report a Bug"
msgstr "Zgłoś błąd"

msgid "Request a Feature"
msgstr "Poproś o funkcję"

msgid "Zoom"
msgstr "Powiększ"

msgid "Fit"
msgstr "Dopasuj"

msgid "Centre"
msgstr "Wyśrodkuj"

msgid "Fill"
msgstr "Wypełnij"

msgid "Tile"
msgstr "Kafelki"

msgid "Span"
msgstr "Rozciągnij"

msgid "Make Every Workspace Your Own"
msgstr "Spersonalizuj każdy obszar roboczy"

msgid "Use different wallpapers and rendering styles per workspace even on a single-monitor setup. Enable Workspace Specificity from the Workspaces tab."
msgstr "Używaj różnych tapet dla obszarów roboczych nawet na jednym monitorze. Włącz to w zakładce Obszary robocze."

msgid "Workspaces"
msgstr "Obszary robocze"

msgid "A Visual Identity for Every Workspace"
msgstr "Wizualna tożsamość dla obszarów roboczych"

msgid "Use wallpapers to make workspaces instantly recognizable and easier to navigate."
msgstr "Użyj tapet, aby obszary robocze były natychmiast rozpoznawalne."

msgid "Works with Any Monitor Setup"
msgstr "Działa z każdą konfiguracją monitorów"

msgid "Give every workspace its own wallpaper and scaling strategy, whether you use one monitor or several."
msgstr "Nadaj każdemu obszarowi jego własną tapetę niezależnie od liczby monitorów."

msgid "Override Only What Should Be Different"
msgstr "Zmieniaj tylko to, co konieczne"

msgid "Every workspace starts with the settings from the main tab. Choose a different image or rendering mode only where needed."
msgstr "Każdy obszar zaczyna od głównych ustawień. Zmieniaj tapetę tylko tam, gdzie to potrzebne."

msgid "Workspace Specificity"
msgstr "Specyfika obszarów roboczych"

msgid "Turn on workspace-aware backgrounds, then choose how many workspace configurations to show."
msgstr "Włącz tła dla obszarów roboczych i wybierz ile konfiguracji wyświetlić."

msgid "Enable Workspace Specificity"
msgstr "Włącz specyfikę obszarów roboczych"

msgid "When disabled, Wallshuffle continues using the main per-monitor configuration."
msgstr "Gdy wyłączone, Wallshuffle używa głównej konfiguracji dla monitorów."

msgid "Brief Dark Transition When Switching"
msgstr "Krótkie przyciemnienie przy zmianie"

msgid "Due to how GNOME applies workspace backgrounds, the desktop may appear dark very briefly while the next background loads. This only occurs when Workspace Specificity is enabled."
msgstr "Ekran może na moment pociemnieć podczas ładowania następnego tła."

msgid "Workspace Configuration Slots"
msgstr "Sloty konfiguracji obszarów"

msgid "Match the number of workspaces you normally use. Add extra slots when using dynamic workspaces."
msgstr "Dopasuj do liczby używanych obszarów roboczych."

msgid "Per-Workspace Overrides"
msgstr "Nadpisania dla obszarów roboczych"

msgid "Open a workspace below to override its inherited scaling strategy or static image for each monitor."
msgstr "Otwórz obszar poniżej, aby nadpisać ustawienia dla każdego monitora."

msgid "Use Monitor Default"
msgstr "Użyj domyślnego dla monitora"

msgid "Workspace %d"
msgstr "Obszar roboczy %d"

msgid "1 connected display"
msgstr "1 podłączony ekran"

msgid "%d connected displays"
msgstr "%d podłączonych ekranów"

msgid "%s Scaling Strategy"
msgstr "Strategia skalowania %s"

msgid "%s   Monitor default: %s"
msgstr "%s   Domyślnie monitor: %s"

msgid "%s Specific Static Image"
msgstr "Statyczny obraz dla %s"

msgid "Monitor Default: %s"
msgstr "Domyślnie monitor: %s"

msgid "Select Static Image for Workspace %d, %s"
msgstr "Wybierz obraz dla obszaru %d, %s"